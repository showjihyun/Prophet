# ============================================================================
# Prophet (MCASP) — Backend Environment Variables
# Copy to `.env` and adjust values for your environment.
# ============================================================================

# ── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://prophet:secret@localhost:5433/prophet
VALKEY_URL=valkey://localhost:6379/0

# ── LLM Providers ───────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
# Default Ollama model: llama3.1:8b (4.7 GB on disk, ~5.6 GiB VRAM).
# Designed for GPU inference via:
#   docker compose -f docker-compose.yml -f docker-compose.gpu.yml up -d
# Runs at ~200+ tok/s on an RTX 4070-class GPU.
# CPU-only laptops should override to llama3.2:1b (~1.3 GB, ~2 GiB RAM)
# by setting OLLAMA_DEFAULT_MODEL and SLM_MODEL below.
OLLAMA_DEFAULT_MODEL=llama3.1:8b
SLM_MODEL=llama3.1:8b
OLLAMA_EMBED_MODEL=llama3.1:8b
ANTHROPIC_API_KEY=
ANTHROPIC_DEFAULT_MODEL=claude-sonnet-4-6
OPENAI_API_KEY=
OPENAI_DEFAULT_MODEL=gpt-4o
OPENAI_EMBED_MODEL=text-embedding-3-small
GEMINI_API_KEY=
GEMINI_DEFAULT_MODEL=gemini-2.0-flash
GEMINI_EMBED_MODEL=models/text-embedding-004
VLLM_BASE_URL=
VLLM_DEFAULT_MODEL=meta-llama/Llama-3.1-8B-Instruct
VLLM_MAX_CONCURRENT=64

# ── CORS ────────────────────────────────────────────────────────────────────
CORS_ALLOW_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ── JWT Auth ────────────────────────────────────────────────────────────────
JWT_SECRET=prophet-dev-secret-change-in-production
JWT_ALGORITHM=HS256
JWT_TOKEN_EXPIRE_HOURS=24

# ── Embedding ───────────────────────────────────────────────────────────────
EMBEDDING_DIM=768

# ── LLM Inference Defaults ─────────────────────────────────────────────────
LLM_DEFAULT_MAX_TOKENS=512
LLM_DEFAULT_TEMPERATURE=0.7
LLM_TIMEOUT_SECONDS=10.0
LLM_RETRY_COUNT=3
LLM_RETRY_DELAY_SECONDS=1.0

# ── LLM Engine Control ─────────────────────────────────────────────────────
DEFAULT_LLM_PROVIDER=ollama
SLM_LLM_RATIO=0.5
LLM_TIER3_RATIO=0.1
LLM_AVG_COST_PER_TIER3_CALL=0.003
LLM_TIER1_LATENCY_MS=5.0
LLM_TIER3_LATENCY_MS=500.0

# ── LLM Cache / Gateway ────────────────────────────────────────────────────
LLM_CACHE_TTL=3600
LLM_INMEMORY_CACHE_MAX_SIZE=1000
LLM_VECTOR_SIMILARITY_THRESHOLD=0.95
LLM_GATEWAY_BATCH_SIZE=32
LLM_GATEWAY_MAX_WAIT_MS=100
LLM_BUDGET_DOWNGRADE_THRESHOLD=0.20
SLM_BATCH_SIZE=32

# ── Simulation ──────────────────────────────────────────────────────────────
SIM_MAX_CONCURRENT=3
SIM_MAX_SIMULATIONS=50
SIM_TTL_SECONDS=86400
SIM_DEFAULT_MAX_STEPS=50
SIM_DEFAULT_RANDOM_SEED=42
MONTE_CARLO_DEFAULT_RUNS=100

# ── Agent ───────────────────────────────────────────────────────────────────
AGENT_MAX_MEMORIES=1000
AGENT_MAX_PERSONALITY_DRIFT=0.3

# ── Cascade / Diffusion ────────────────────────────────────────────────────
CASCADE_VIRAL_THRESHOLD=0.15
CASCADE_SLOW_ADOPTION_STEPS=5
SENTIMENT_EXPERT_ALPHA=0.3
BRIDGE_TRUST_FACTOR=0.6
